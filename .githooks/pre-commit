#!/bin/bash
set -euo pipefail

# Check formatting of staged files only. Fails the commit if any are
# unformatted; fix with `npm run format` then re-stage.
# Bypass with `git commit --no-verify`.

files=()
while IFS= read -r f; do
  files+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#files[@]} -eq 0 ]]; then
  exit 0
fi

echo "pre-commit: checking formatting of staged files..."
npx prettier --check --ignore-unknown "${files[@]}"
